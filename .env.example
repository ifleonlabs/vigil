# Copy to .env and adjust. All vars are prefixed VIGIL_.

# Set to "production" to enable hardening (refuses to boot with the default secret).
VIGIL_ENV=development

# REQUIRED in production. Generate a strong one:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
VIGIL_SECRET_KEY=dev-secret-change-me

# Storage (SQLite by default; a Postgres URL also works for the app DB)
VIGIL_DATABASE_URL=sqlite:///vigil.db
VIGIL_QUEUE_PATH=vigil-queue.db

# Auth
VIGIL_ACCESS_TOKEN_MINUTES=1440
VIGIL_AUTH_MAX_ATTEMPTS=20
VIGIL_AUTH_WINDOW_SECONDS=60

# Checking behavior
VIGIL_CHECK_TIMEOUT=10
VIGIL_SCHEDULER_INTERVAL=5
